# Copy to `voice_backend/.env` and fill with your values.

# Fennec ASR
FENNEC_API_KEY=replace_me
FENNEC_SAMPLE_RATE=16000
FENNEC_CHANNELS=1

# Groq (OpenAI-compatible)
GROQ_API_KEY=replace_me
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b

# Inworld TTS
INWORLD_API_KEY=base64_key
INWORLD_MODEL_ID=inworld-tts-1
INWORLD_VOICE_ID=Olivia
INWORLD_SAMPLE_RATE=48000
